<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="UTF-8">
    <title>Heavy Steel Co. - Jack Design System</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, sans-serif; background: #f4f7f6; padding: 10px; direction: ltr; margin: 0; }
        .card { background: white; max-width: 1000px; margin: auto; padding: 20px; border-radius: 12px; box-shadow: 0 5px 20px rgba(0,0,0,0.1); }
        .input-row { display: grid; grid-template-columns: repeat(5, 1fr); gap: 10px; background: #eef2f3; padding: 15px; border-radius: 8px; margin-bottom: 15px; }
        label { font-weight: bold; display: block; margin-bottom: 2px; font-size: 12px; }
        input, select { width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 5px; font-size: 13px; }
        button { border: none; padding: 12px; border-radius: 8px; font-size: 16px; cursor: pointer; font-weight: bold; width: 100%; }
        .btn-calc { background: #27ae60; color: white; margin-top: 5px; }
        .btn-print { background: #34495e; color: white; display: none; margin-top: 10px; }
        .main-grid { display: none; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 10px; }
        .drawing-card { border: 1px solid #000; background: #fff; text-align: center; display: flex; flex-direction: column; justify-content: space-between; }
        .drawing-card h4 { background: #34495e; color: white; margin: 0; padding: 4px; font-size: 12px; }
        .svg-wrap { flex-grow: 1; display: flex; align-items: center; justify-content: center; padding: 10px; }
        .large-draw { min-height: 480px; }
        .small-draw { min-height: 280px; border-style: dashed; }
        svg { width: 100%; height: auto; max-height: 450px; }
        .hole-label { font-size: 15px; fill: #2c3e50; font-weight: 900; }
        .total-dim-text { font-size: 16px; font-weight: bold; fill: #000; }
        .c-box { margin: 5px auto; padding: 5px; background: #fff9c4; border: 1px dashed #fbc02d; font-weight: bold; color: #d35400; font-size: 15px; width: 90%; }
        .table-section { margin-top: 15px; display: none; }
        table { width: 100%; border-collapse: collapse; border: 2px solid #34495e; background: #fff; }
        th { background: #34495e; color: white; padding: 6px; font-size: 13px; }
        td { border: 1px solid #ddd; padding: 6px; text-align: center; font-weight: bold; font-size: 14px; }
        @media print { 
            @page { size: A4 portrait; margin: 0.5cm; }
            body { background: white; padding: 0; margin: 0; }
            .no-print { display: none !important; }
            .card { box-shadow: none; border: 4px double #34495e; width: 100%; padding: 15px; margin: 0; box-sizing: border-box; min-height: 28cm; zoom: 85%; }
            .main-grid { display: grid !important; }
            .table-section { display: block !important; }
        }
    </style>
</head>
<body>
<div class="card">
    <div style="text-align: center; margin-bottom: 20px; border-bottom: 3px double #34495e; padding-bottom: 10px;">
        <h1 style="color: #2c3e50; margin: 0; font-size: 28px;">Heavy Steel Co.</h1>
    </div>
    
    <div class="no-print">
        <h2 style="text-align: center; margin:0 0 10px 0;">Universal Jack Design System</h2>
        <div class="input-row">
            <div><label>Closed (cm)</label><input type="number" id="closeLen" value="150"></div>
            <div><label>Open (cm)</label><input type="number" id="openLen" value="250"></div>
            <div><label>Clearance (cm)</label><input type="number" id="clearance" value="3"></div>
            <div><label>Hole Count</label><input type="number" id="holeCount" value="4"></div>
            <div><label>Head Size</label><select id="headSize"><option value="16">16 cm</option><option value="12">12 cm</option></select></div>
        </div>
        <button class="btn-calc" onclick="drawSystem()">Generate Engineering Blueprint</button>
    </div>

    <div id="headerInfo" style="display:none; border-bottom: 2px solid #000; padding-bottom: 5px; margin-bottom: 10px;">
        <h3 style="margin:0; text-align:center;">Trench Box Jack Operation Blueprint</h3>
        <p style="text-align:center; font-weight:bold; margin:5px 0;">
            Closed: <span id="h_close"></span> | Open: <span id="h_open"></span> | Clearance: <span id="h_clear"></span> | Tube: <span id="h_tube" style="color:red"></span> | Head: <span id="h_head"></span>
        </p>
    </div>

    <div id="mainGrid" class="main-grid">
        <div class="drawing-card large-draw">
            <h4>Female Tube (Measured from Head)</h4>
            <div id="fSVG" class="svg-wrap"></div>
            <div class="c-box">Distance from Tube End to Last Hole: <span id="c1_f_box"></span> cm</div>
        </div>
        <div class="drawing-card large-draw">
            <h4>Male Tube (Measured from Tube End)</h4>
            <div id="mSVG" class="svg-wrap"></div>
            <div class="c-box">Distance C from Male Tube End to Hole: <span id="c1_m_box"></span> cm</div>
        </div>
        <div class="drawing-card small-draw">
            <h4>Closed Position</h4>
            <div id="cSVG" class="svg-wrap"></div>
        </div>
        <div class="drawing-card small-draw">
            <h4>Open Position</h4>
            <div id="oSVG" class="svg-wrap"></div>
        </div>
    </div>

    <div id="tableArea" class="table-section">
        <h4 style="text-align: center; margin: 10px 0 5px 0; color: #1a73e8;">Operating Lengths Guide (Length per Hole)</h4>
        <table>
            <thead><tr><th>Hole No.</th><th>Hole Location in Female (T)</th><th>Total Resulting Jack Length</th><th>Status</th></tr></thead>
            <tbody id="tableBody"></tbody>
        </table>
    </div>
    
    <button id="printBtn" class="btn-print no-print" onclick="window.print()">Print Blueprint & Guide 📄</button>
</div>

<script>
function drawSystem() {
    const close = parseFloat(document.getElementById('closeLen').value);
    const open = parseFloat(document.getElementById('openLen').value);
    const clear = parseFloat(document.getElementById('clearance').value);
    const count = parseInt(document.getElementById('holeCount').value);
    const H = parseFloat(document.getElementById('headSize').value);

    if (!close || !open || isNaN(clear) || count < 2) return;

    let L = close - (H*2) - clear;
    let moveRange = open - close;
    let overlapValue = (H*2 + (L*2)) - open;
    let c1 = Math.round(overlapValue / 2);

    document.getElementById('h_close').innerText = close;
    document.getElementById('h_open').innerText = open;
    document.getElementById('h_clear').innerText = clear;
    document.getElementById('h_tube').innerText = Math.round(L);
    document.getElementById('h_head').innerText = H;
    document.getElementById('c1_f_box').innerText = c1;
    document.getElementById('c1_m_box').innerText = c1;
    document.getElementById('headerInfo').style.display = 'block';

    const getHolePos = (idx) => {
        let base = Math.floor(moveRange / (count-1));
        let rem = moveRange % (count-1);
        return (idx * base) + Math.min(idx, rem);
    };

    let tableRows = '';
    for(let i=0; i<count; i++) {
        let move = getHolePos(i);
        let currentTotal = close + move;
        let T_val = c1 + clear + move;
        let status = (i === 0) ? "Closed" : (i === count-1 ? "Max Open" : "-");
        tableRows += `<tr><td>Hole ${i+1}</td><td>${Math.round(T_val)} cm</td><td>${currentTotal} cm</td><td>${status}</td></tr>`;
    }
    document.getElementById('tableBody').innerHTML = tableRows;

    const svgDefs = `<defs><marker id="arrow" viewBox="0 0 10 10" refX="5" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse"><path d="M 0 0 L 10 5 L 0 10 z" fill="black" /></marker></defs>`;

    const getHoles = (type) => {
        let hContent = '';
        if (type === 'M') {
            let lastMove = getHolePos(count-1);
            let distFromHead = c1 + clear + lastMove;
            let distFromEnd = L - distFromHead;
            let y = 50 + (distFromHead/L * 400);
            hContent += `
                <line x1="125" y1="${y}" x2="225" y2="${y}" stroke="#2980b9" stroke-dasharray="3" />
                <circle cx="125" cy="${y}" r="6" fill="black" stroke="black" />
                <text x="230" y="${y}" dominant-baseline="middle" class="hole-label">C: ${Math.round(distFromEnd)}</text>
            `;
        } else {
            for(let i=0; i<count; i++) {
                let move = getHolePos(i);
                let valFromHead = c1 + clear + move;
                let y = 50 + (valFromHead/L * 400);
                hContent += `
                    <line x1="125" y1="${y}" x2="225" y2="${y}" stroke="#2980b9" stroke-dasharray="3" />
                    <circle cx="125" cy="${y}" r="6" fill="white" stroke="black" />
                    <text x="230" y="${y}" dominant-baseline="middle" class="hole-label">T${i+1}: ${Math.round(valFromHead)}</text>
                `;
            }
        }
        return hContent;
    };

    const drawTube = (type) => `
        <svg viewBox="0 0 300 500">
            ${svgDefs}
            <rect x="100" y="50" width="50" height="400" fill="#ecf0f1" stroke="black" stroke-width="2" />
            <path d="M 75 50 L 75 30 Q 75 10 95 10 L 155 10 Q 175 10 175 30 L 175 50 Z" fill="#7f8c8d" stroke="black" stroke-width="2" />
            <circle cx="125" cy="30" r="10" fill="white" stroke="black" />
            <line x1="190" y1="10" x2="190" y2="50" stroke="black" stroke-width="1.5" marker-start="url(#arrow)" marker-end="url(#arrow)" />
            <text x="245" y="35" text-anchor="start" fill="black" font-weight="bold" font-size="14">${H} cm</text>
            ${getHoles(type)}
            <line x1="50" y1="50" x2="50" y2="450" stroke="black" marker-start="url(#arrow)" marker-end="url(#arrow)" />
            <text x="40" y="250" transform="rotate(-90 40,250)" font-weight="bold">Tube: <tspan fill="red">${Math.round(L)}</tspan> cm</text>
        </svg>
    `;

    const drawAssembly = (isOpen) => {
        let total = isOpen ? open : close;
        let tubeLen = 220;
        let femaleX = isOpen ? 280 : 105;
        return `
            <svg viewBox="0 0 600 200">
                ${svgDefs}
                <path d="M 90 70 L 60 70 Q 50 70 50 80 L 50 120 Q 50 130 60 130 L 90 130 Z" fill="#7f8c8d" stroke="black" />
                <circle cx="70" cy="100" r="6" fill="white" stroke="black" />
                <rect x="90" y="85" width="${tubeLen}" height="30" fill="#bdc3c7" stroke="black" />
                <rect x="${femaleX}" y="80" width="220" height="40" fill="rgba(236, 240, 241, 0.6)" stroke="black" />
                <path d="M ${femaleX + 220} 70 L ${femaleX + 250} 70 Q ${femaleX + 260} 70 ${femaleX + 260} 80 L ${femaleX + 260} 120 Q ${femaleX + 260} 130 ${femaleX + 250} 130 L ${femaleX + 220} 130 Z" fill="#7f8c8d" stroke="black" />
                <circle cx="${femaleX + 240}" cy="100" r="6" fill="white" stroke="black" />
                <line x1="50" y1="160" x2="${femaleX + 260}" y2="160" stroke="black" stroke-width="1.5" marker-start="url(#arrow)" marker-end="url(#arrow)" />
                <text x="${(50 + femaleX + 260) / 2}" y="185" text-anchor="middle" class="total-dim-text">Total: <tspan fill="red">${total}</tspan> cm</text>
                ${!isOpen ? `
                    <line x1="90" y1="100" x2="105" y2="100" stroke="red" stroke-width="2" />
                    <line x1="90" y1="92" x2="90" y2="108" stroke="red" stroke-width="2" />
                    <line x1="105" y1="92" x2="105" y2="108" stroke="red" stroke-width="2" />
                    <text x="97" y="65" text-anchor="middle" fill="red" font-weight="bold" font-size="13">Clear: ${clear}cm</text>
                ` : ''}
            </svg>
        `;
    };

    document.getElementById('fSVG').innerHTML = drawTube('F');
    document.getElementById('mSVG').innerHTML = drawTube('M');
    document.getElementById('cSVG').innerHTML = drawAssembly(false);
    document.getElementById('oSVG').innerHTML = drawAssembly(true);

    document.getElementById('mainGrid').style.display = 'grid';
    document.getElementById('tableArea').style.display = 'block';
    document.getElementById('printBtn').style.display = 'block';
}
</script>
</body>
</html>
